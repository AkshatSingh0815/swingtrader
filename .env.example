# ==== Database ====
DATABASE_URL=sqlite:///./database/swingtrader.db

# ==== News / sentiment ====
NEWSAPI_KEY=your_newsapi_key_here
FINNHUB_KEY=your_finnhub_key_here_optional

# ==== Market data (optional extras; yfinance/nsepython need no key) ====
ALPHAVANTAGE_KEY=your_alphavantage_key_optional

# ==== Alerts ====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=app_password_here
ALERT_EMAIL_TO=you@example.com

# ==== Scan behaviour ====
SCAN_UNIVERSE=ALL_NSE          # ALL_NSE | NIFTY50 | NIFTY500 | WATCHLIST
MAX_WORKERS=10                 # parallel data-fetch workers
MIN_PRICE=5                    # ignore illiquid sub-Rs.5 stocks in main scan
MIN_AVG_VOLUME=50000

# ==== App ====
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
ENV=development
